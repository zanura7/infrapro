# ============================================================
# .env for docker-compose deployment
# Copy this to .env on the VPS and fill in the secrets.
# ============================================================

APP_NAME="Projek Infra"
APP_ENV=production
APP_KEY=                              # leave blank — entrypoint will generate
APP_DEBUG=false
APP_URL=http://YOUR_VPS_IP:8080       # change to https://domain.tld once SSL is set up

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (matches docker-compose mysql service) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=projek_infra
DB_USERNAME=projek
DB_PASSWORD=CHANGE-ME-STRONG-PASS
DB_ROOT_PASSWORD=CHANGE-ME-STRONGER

# --- Cache / queue / session pakai Redis ---
BROADCAST_DRIVER=log
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# --- Mail (set up later) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Public port nginx binds to on the host ---
APP_PORT=8080

# --- Viber AI ---
VIBER_API_KEY=CHANGE-ME-VIBER-KEY
AI_BASE_URL=https://gstd.viber.id/v1
AI_TEXT_MODEL=grok-4.20-beta
AI_IMAGE_MODEL=grok-imagine-1.0
AI_VIDEO_MODEL=grok-imagine-1.0-video
